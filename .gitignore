# Terraform state and sensitive files
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform/
.terraform.lock.hcl
terraform.tfvars

# VM SSH key (generated by Terraform)
terraform/files/vm_key
terraform/files/vm_key.pub

# Ansible generated inventory (generated by Terraform)
ansible/inventory/hosts.yml
ansible/inventory/*.yml

# Kubeconfig (fetched from cluster)
kubeconfig-local.yml

# Environment variables (contains secrets)
.envrc

# Claude Code
.claude/

# Docs (internal notes)
vault/init-vault.md

# Editor and OS files
.DS_Store
*.swp
*.swo
.idea/
.vscode/

# Logs
*.log
notes.sh
doc/
tmp/
/gitops/vault/init-vault.md
