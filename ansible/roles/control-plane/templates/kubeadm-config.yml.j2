# ==============================================================================
# kubeadm-config.yml.j2 — kubeadm initialization configuration
# ==============================================================================
# This template is rendered on cp-01 and passed to `kubeadm init --config`.
#
# Key setting: skipPhases: [addon/kube-proxy]
# We skip the kube-proxy addon because Cilium will replace it in eBPF mode.
# Cilium with kubeProxyReplacement=true handles all kube-proxy functionality
# via eBPF programs, which is more efficient.
# ==============================================================================

apiVersion: kubeadm.k8s.io/v1beta4
kind: InitConfiguration

# Skip kube-proxy installation — Cilium replaces it
skipPhases:
  - addon/kube-proxy

localAPIEndpoint:
  advertiseAddress: "{{ ansible_host }}"  # cp-01's IP (10.0.0.10)
  bindPort: 6443

nodeRegistration:
  criSocket: unix:///var/run/containerd/containerd.sock
  name: "{{ inventory_hostname }}"

---
apiVersion: kubeadm.k8s.io/v1beta4
kind: ClusterConfiguration

kubernetesVersion: "v{{ k8s_version }}.0"

controlPlaneEndpoint: "{{ ansible_host }}:6443"

# certSANs: adds 127.0.0.1 so kubectl works via SSH tunnel without TLS errors
certSANs:
  - "127.0.0.1"
  - "{{ ansible_host }}"

networking:
  podSubnet: "{{ pod_cidr }}"         # 10.244.0.0/16 — managed by Cilium
  serviceSubnet: "{{ service_cidr }}" # 10.96.0.0/12 — default

# etcd uses local disk by default
etcd:
  local:
    dataDir: /var/lib/etcd

# API server extra args for security and flexibility
apiServer:
  extraArgs:
    - name: authorization-mode
      value: "Node,RBAC"

---
apiVersion: kubelet.config.k8s.io/v1beta1
kind: KubeletConfiguration

# Use systemd cgroup driver — must match containerd's SystemdCgroup=true
cgroupDriver: systemd
